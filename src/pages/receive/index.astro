---
import { env } from "cloudflare:workers";
import ReceiveCard from "../../components/receive/ReceiveCard.astro";
import ReceiveClientScript from "../../components/receive/ReceiveClientScript.astro";
import Layout from "../../layouts/Layout.astro";

const workerUrl = env.WORKER_URL;
---

<Layout title="Connect — Receive File">
  <div class="flex min-h-screen flex-col items-center justify-center px-4 py-8">
    <ReceiveCard />
  </div>
  <ReceiveClientScript workerUrl={workerUrl} />
</Layout>

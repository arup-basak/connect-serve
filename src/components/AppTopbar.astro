---
interface Props {
  logo?: string;
  backHref?: string;
  backLabel?: string;
}
const {
  logo = "Connect",
  backHref = "/",
  backLabel = "\u2190 Back to app",
} = Astro.props;
---

<div class="mx-auto mb-12 flex max-w-3xl items-center justify-between px-6 pb-0 pt-6">
  <div class="text-[13px] font-bold uppercase tracking-[0.14em] text-blue-500">{logo}</div>
  <a
    href={backHref}
    class="text-[13px] text-neutral-500 no-underline transition-colors hover:text-neutral-200">{backLabel}</a>
</div>

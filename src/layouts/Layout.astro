---
import "../styles/global.css";

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-[#0a0a0a] font-sans text-neutral-200 antialiased">
    <slot />
  </body>
</html>
